# API configuration
APP_ENV=local
MODEL_NAME=customer_churn_classifier
MODEL_STAGE=local
MODEL_PATH=models/churn_pipeline.joblib
METADATA_PATH=models/model_metadata.json
PREDICTION_LOG_PATH=monitoring/prediction_logs.jsonl
