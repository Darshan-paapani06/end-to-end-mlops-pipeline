# MLflow configuration
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=customer-churn-mlops

# Optional cloud deployment placeholders
AWS_REGION=ap-south-1
GCP_PROJECT_ID=your-gcp-project-id
